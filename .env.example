# Copy this file to `.env` and fill in your own key.
#
# Tidy uses Google's Gemini API for natural-language rule parsing and the
# Smart Rename feature. Without a key, those AI features fall back to a local
# heuristic and the rest of the app works normally.
#
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-api-key-here
